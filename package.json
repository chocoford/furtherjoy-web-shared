{
  "name": "@furtherjoy/web-shared",
  "version": "0.1.4",
  "description": "Shared brand data, nav config, and i18n strings for FurtherJoy web properties (portal + shop).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
